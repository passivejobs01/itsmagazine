# content_tools 환경설정 예시 — 복사해서 .env(또는 .env_linux)로 쓰고 값 채우기
#   cp .env.example .env

# ===== 서버 =====
MY_CHANNEL_URL=https://www.youtube.com/@your-channel
PORT=8003
# 공개 URL — 웹훅·MP3·요약·리포트 링크가 모두 이 값에서 파생.
#   로컬만: http://localhost:8003   / 외부 공개: https://your-server.example.com
FASTAPI_PUBLIC_URL=http://localhost:8003

# YouTube Data API v3 키 (https://console.cloud.google.com)
YOUTUBE_API_KEY=
# 수집 영상 저장 루트
RESEARCH_BASE_DIR=./research

# ===== Ollama (로컬 LLM) =====
OLLAMA_HOST=http://localhost:11434
# 요약/블로그 생성 모델 — 품질: gemma4:12b, 빠르게: qwen3:8b
SUMMARY_MODEL=gemma4:12b
SUMMARY_NUM_CTX=16384
SUMMARY_CHUNK_CHARS=4000

# ===== Whisper STT =====
# tiny | base | small | medium | large-v2 | large-v3 | large-v3-turbo
STT_MODEL=large-v3-turbo
STT_DEVICE=auto          # auto | cpu | cuda
AUDIO_DIR=./audio

# ===== Telegram 봇 =====
# @BotFather에서 발급. 그룹 토픽을 쓰려면 /setprivacy → Disable 후 봇 재추가.
TELEGRAM_BOT_TOKEN=
# 기본 수신 chat_id. 그룹이면 음수(예: -1001234567890)
TELEGRAM_CHAT_ID=
# (선택) 토픽(Forum) 라우팅 — 각 토픽의 message_thread_id
TG_TOPIC_SUMMARY=
TG_TOPIC_BLOG=
TG_TOPIC_TTS=
# (선택) 텔레그램 TTS 토픽 기본 음성 이름. 비우면 첫 등록 음성 사용
TTS_DEFAULT_VOICE=

# ===== WordPress 자동 발행 =====
WP_URL=https://your-blog.example.com
WP_USER=
# WordPress 사용자 → 프로필 → "애플리케이션 비밀번호"에서 발급 (로그인 비번 아님)
WP_APP_PASSWORD=
WP_DEFAULT_STATUS=draft   # draft | publish
